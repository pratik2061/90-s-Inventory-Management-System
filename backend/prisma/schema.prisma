generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PaymentMode {
  CASH
  ONLINE
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Item {
  id       String   @id @default(uuid())
  name     String 
  code     String   
  price    Float
  colors   String[]
  quantity Int      @default(0)

  saleItems                SaleItem[]
  exchangedItemsAsOriginal ExchangedItem[] @relation("OriginalItem")
  exchangedItemsAsNew      ExchangedItem[] @relation("NewItem")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id    String @id @default(uuid())
  name  String
  phone String

  sales          Sale[]
  exchangedItems ExchangedItem[]

  createdAt DateTime @default(now())
}

model Sale {
  id          String      @id @default(uuid())
  customerId  String?
  paymentMode PaymentMode
  totalAmount Float
  discount    Float       @default(0)
  note        String?

  customer Customer?  @relation(fields: [customerId], references: [id])
  items    SaleItem[]
  exchanges ExchangedItem[]

  createdAt DateTime @default(now())
}

model SaleItem {
  id       String @id @default(uuid())
  saleId   String
  itemId   String
  quantity Int
  price    Float

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id])
}

model ExchangedItem {
  id             String  @id @default(uuid())
  customerId     String?
  saleId         String? 
  originalItemId String
  newItemId      String
  quantity       Int
  note           String?

  customer     Customer? @relation(fields: [customerId], references: [id])
  sale         Sale?    @relation(fields: [saleId], references: [id])
  originalItem Item     @relation("OriginalItem", fields: [originalItemId], references: [id])
  newItem      Item     @relation("NewItem", fields: [newItemId], references: [id])

  createdAt DateTime @default(now())
}
